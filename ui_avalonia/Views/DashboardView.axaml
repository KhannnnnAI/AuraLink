<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ui_avalonia.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="680"
             x:Class="ui_avalonia.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="BgColor" Color="#F4F5F7"/>
          <SolidColorBrush x:Key="CardBgColor" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="CyanAccent" Color="#0B8491"/>
          <SolidColorBrush x:Key="PinkAccent" Color="#D21B6A"/>
          <SolidColorBrush x:Key="GreenAccent" Color="#1AA251"/>
          <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
          <SolidColorBrush x:Key="TextGray" Color="#6C727F"/>
          <SolidColorBrush x:Key="DhcpBadgeBg" Color="#E6F4EA"/>
          <SolidColorBrush x:Key="DhcpBadgeBorderText" Color="#137333"/>
          <SolidColorBrush x:Key="StaticBadgeBg" Color="#FCE8E6"/>
          <SolidColorBrush x:Key="StaticBadgeBorderText" Color="#C5221F"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="BgColor" Color="#14151A"/>
          <SolidColorBrush x:Key="CardBgColor" Color="#1E1F28"/>
          <SolidColorBrush x:Key="CyanAccent" Color="#00E5FF"/>
          <SolidColorBrush x:Key="PinkAccent" Color="#FF007F"/>
          <SolidColorBrush x:Key="GreenAccent" Color="#00FF87"/>
          <SolidColorBrush x:Key="BorderColor" Color="#2A2B36"/>
          <SolidColorBrush x:Key="TextGray" Color="#8B8C9A"/>
          <SolidColorBrush x:Key="DhcpBadgeBg" Color="#1D2D26"/>
          <SolidColorBrush x:Key="DhcpBadgeBorderText" Color="#00FF87"/>
          <SolidColorBrush x:Key="StaticBadgeBg" Color="#2D1F1D"/>
          <SolidColorBrush x:Key="StaticBadgeBorderText" Color="#FF5252"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Border.Card">
      <Setter Property="Background" Value="{DynamicResource SemiColorBackground2}"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="Margin" Value="6"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.DeviceCard">
      <Setter Property="Background" Value="{DynamicResource SemiColorBackground2}"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="Margin" Value="0,0,12,0"/>
      <Setter Property="Width" Value="180"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
  </UserControl.Styles>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
    <Grid RowDefinitions="Auto, Auto, Auto" Margin="4">
      
      <!-- HEADER -->
      <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="6,0,6,12">
        <!-- Title and Subtitle -->
        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <ic:SymbolIcon Symbol="Home" FontSize="26" Foreground="{DynamicResource CyanAccent}" VerticalAlignment="Center"/>
            <TextBlock Text="DASHBOARD OVERVIEW" FontSize="22" FontWeight="Heavy" Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center" LetterSpacing="1"/>
          </StackPanel>
          <TextBlock Text="Real-time network monitoring and diagnostics" FontSize="13" Foreground="{DynamicResource TextGray}"/>
        </StackPanel>
        
        <!-- Interface Selector and Clock -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
          <!-- Card Selector -->
          <StackPanel Spacing="4" VerticalAlignment="Center">
            <TextBlock Text="Card Mạng:" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextGray}"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <ComboBox ItemsSource="{Binding NetworkCards}" SelectedItem="{Binding SelectedCard}" Width="240" Height="34" VerticalAlignment="Center">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <Button Command="{Binding RefreshCardsCommand}" Width="34" Height="34" Theme="{StaticResource ButtonOutline}" Padding="0" VerticalAlignment="Center">
                <ic:SymbolIcon Symbol="ArrowClockwise" FontSize="16" HorizontalAlignment="Center"/>
              </Button>
            </StackPanel>
          </StackPanel>
          
          <!-- Separator Line -->
          <Border Width="1" Height="40" Background="{DynamicResource BorderColor}" VerticalAlignment="Center"/>
          
          <!-- Live Clock -->
          <StackPanel VerticalAlignment="Center" MinWidth="110">
            <TextBlock Text="{Binding CurrentDate}" FontSize="11" Foreground="{DynamicResource TextGray}" HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding CurrentTime}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource SemiColorText0}" HorizontalAlignment="Right"/>
          </StackPanel>
        </StackPanel>
      </Grid>

      <!-- TOP CARDS -->
      <Grid Grid.Row="1" ColumnDefinitions="*, *, *" Margin="0,8">
        
        <!-- Card 1: Connection Status -->
        <Border Grid.Column="0" Classes="Card">
          <Grid RowDefinitions="Auto, *, Auto">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
              <ic:SymbolIcon Symbol="Globe" FontSize="18" Foreground="{DynamicResource GreenAccent}" VerticalAlignment="Center"/>
              <TextBlock Text="Trạng Thái Kết Nối" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextGray}" VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,12">
              <TextBlock Text="Trực Tuyến" FontSize="26" FontWeight="Heavy" Foreground="{DynamicResource GreenAccent}"/>
              <StackPanel Spacing="4" Margin="0,8,0,0">
                <Grid ColumnDefinitions="*, Auto">
                  <TextBlock Grid.Column="0" Text="Gateway Ping:" FontSize="11" Foreground="{DynamicResource TextGray}"/>
                  <TextBlock Grid.Column="1" Text="{Binding GatewayPing}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SemiColorText0}"/>
                </Grid>
                <Grid ColumnDefinitions="*, Auto">
                  <TextBlock Grid.Column="0" Text="Internet Ping:" FontSize="11" Foreground="{DynamicResource TextGray}"/>
                  <TextBlock Grid.Column="1" Text="{Binding InternetPing}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SemiColorText0}"/>
                </Grid>
                <Grid ColumnDefinitions="*, Auto">
                  <TextBlock Grid.Column="0" Text="Phân giải DNS:" FontSize="11" Foreground="{DynamicResource TextGray}"/>
                  <TextBlock Grid.Column="1" Text="{Binding DnsResolution}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SemiColorText0}"/>
                </Grid>
              </StackPanel>
            </StackPanel>
            
            <Button Grid.Row="2" Command="{Binding CheckConnectionCommand}" IsEnabled="{Binding !IsBusy}" Theme="{StaticResource ButtonPrimary}" HorizontalAlignment="Stretch" Height="32">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <ic:SymbolIcon Symbol="Play" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Kiểm Tra Kết Nối" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </Grid>
        </Border>

        <!-- Card 2: IP Configuration -->
        <Border Grid.Column="1" Classes="Card">
          <Grid RowDefinitions="Auto, *, Auto">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
              <ic:SymbolIcon Symbol="Wrench" FontSize="18" Foreground="{DynamicResource CyanAccent}" VerticalAlignment="Center"/>
              <TextBlock Text="Cấu Hình Địa Chỉ IP" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextGray}" VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,12">
              <TextBlock Text="{Binding SelectedCard.IpAddress}" FontSize="22" FontWeight="Heavy" Foreground="{DynamicResource SemiColorText0}" TextTrimming="CharacterEllipsis"/>
              <StackPanel Spacing="4" Margin="0,8,0,0">
                <Grid ColumnDefinitions="*, Auto">
                  <TextBlock Grid.Column="0" Text="Subnet Mask:" FontSize="11" Foreground="{DynamicResource TextGray}"/>
                  <TextBlock Grid.Column="1" Text="{Binding SelectedCard.SubnetMask}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SemiColorText0}"/>
                </Grid>
                <Grid ColumnDefinitions="*, Auto">
                  <TextBlock Grid.Column="0" Text="Gateway IP:" FontSize="11" Foreground="{DynamicResource TextGray}"/>
                  <TextBlock Grid.Column="1" Text="{Binding SelectedCard.Gateway}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SemiColorText0}"/>
                </Grid>
                <Grid ColumnDefinitions="*, Auto">
                  <TextBlock Grid.Column="0" Text="Chế độ DHCP:" FontSize="11" Foreground="{DynamicResource TextGray}"/>
                   <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Border CornerRadius="4" Padding="6,2" Background="{DynamicResource DhcpBadgeBg}" BorderBrush="{DynamicResource DhcpBadgeBorderText}" BorderThickness="1" IsVisible="{Binding SelectedCard.IsDhcp}">
                      <TextBlock Text="DHCP (Tự Động)" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource DhcpBadgeBorderText}"/>
                    </Border>
                    <Border CornerRadius="4" Padding="6,2" Background="{DynamicResource StaticBadgeBg}" BorderBrush="{DynamicResource StaticBadgeBorderText}" BorderThickness="1" IsVisible="{Binding !SelectedCard.IsDhcp}">
                      <TextBlock Text="IP Tĩnh (Manual)" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource StaticBadgeBorderText}"/>
                    </Border>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </StackPanel>
            
            <Button Grid.Row="2" Command="{Binding ApplyDhcpCommand}" IsEnabled="{Binding !IsBusy}" Theme="{StaticResource ButtonOutline}" Classes="Warning" HorizontalAlignment="Stretch" Height="32">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <ic:SymbolIcon Symbol="ArrowClockwise" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Khôi Phục DHCP" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </Grid>
        </Border>

        <!-- Card 3: Session Data Stats -->
        <Border Grid.Column="2" Classes="Card">
          <Grid RowDefinitions="Auto, *">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
              <ic:SymbolIcon Symbol="Folder" FontSize="18" Foreground="{DynamicResource PinkAccent}" VerticalAlignment="Center"/>
              <TextBlock Text="Dữ Liệu Phiên Làm Việc" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextGray}" VerticalAlignment="Center"/>
            </StackPanel>
            
            <Grid Grid.Row="1" ColumnDefinitions="*, *" VerticalAlignment="Center" Margin="0,10,0,0">
              <!-- Download Stats -->
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Tải Xuống (Down):" FontSize="11" Foreground="{DynamicResource TextGray}"/>
                <TextBlock Text="{Binding SessionBytesReceivedText}" FontSize="20" FontWeight="Heavy" Foreground="{DynamicResource CyanAccent}"/>
              </StackPanel>
              
              <!-- Upload Stats -->
              <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                <TextBlock Text="Tải Lên (Up):" FontSize="11" Foreground="{DynamicResource TextGray}"/>
                <TextBlock Text="{Binding SessionBytesSentText}" FontSize="20" FontWeight="Heavy" Foreground="{DynamicResource PinkAccent}"/>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </Grid>

      <!-- MIDDLE SECTION (CHARTS) -->
      <Grid Grid.Row="2" ColumnDefinitions="2*, 1*" Margin="0,8">
        
        <!-- Network Traffic Line Chart -->
        <Border Grid.Column="0" Classes="Card" Margin="6">
          <Grid RowDefinitions="Auto, *">
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <ic:SymbolIcon Symbol="Pulse" FontSize="18" Foreground="{DynamicResource CyanAccent}" VerticalAlignment="Center"/>
                <TextBlock Text="Lưu Lượng Mạng Thời Gian Thực" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
              </StackPanel>
              
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse Width="8" Height="8" Fill="{DynamicResource CyanAccent}" VerticalAlignment="Center"/>
                  <TextBlock Text="Tải Xuống (Down):" FontSize="11" Foreground="{DynamicResource TextGray}" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding DownloadSpeedText}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource CyanAccent}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse Width="8" Height="8" Fill="{DynamicResource PinkAccent}" VerticalAlignment="Center"/>
                  <TextBlock Text="Tải Lên (Up):" FontSize="11" Foreground="{DynamicResource TextGray}" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding UploadSpeedText}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource PinkAccent}" VerticalAlignment="Center"/>
                </StackPanel>
              </StackPanel>
            </Grid>

            <Canvas Grid.Row="1" Height="200" MinWidth="500" Background="{DynamicResource SemiColorBackground0}" ClipToBounds="True" Margin="0,10,0,0">
              <!-- Grid Lines -->
              <Line StartPoint="0,0" EndPoint="900,0" Stroke="{DynamicResource SemiColorBorder}" StrokeThickness="1" StrokeDashArray="4,4"/>
              <Line StartPoint="0,40" EndPoint="900,40" Stroke="{DynamicResource SemiColorBorder}" StrokeThickness="1" StrokeDashArray="4,4"/>
              <Line StartPoint="0,80" EndPoint="900,80" Stroke="{DynamicResource SemiColorBorder}" StrokeThickness="1" StrokeDashArray="4,4"/>
              <Line StartPoint="0,120" EndPoint="900,120" Stroke="{DynamicResource SemiColorBorder}" StrokeThickness="1" StrokeDashArray="4,4"/>
              <Line StartPoint="0,140" EndPoint="900,140" Stroke="{DynamicResource SemiColorBorder}" StrokeThickness="1" StrokeDashArray="4,4"/>
              <Line StartPoint="0,160" EndPoint="900,160" Stroke="{DynamicResource SemiColorBorder}" StrokeThickness="1" StrokeDashArray="4,4"/>
              <Line StartPoint="0,180" EndPoint="900,180" Stroke="{DynamicResource SemiColorBorder}" StrokeThickness="1" StrokeDashArray="4,4"/>
              
              <!-- Y-Axis labels -->
              <TextBlock Canvas.Left="8" Canvas.Top="4" Text="10 Gbps" FontSize="9" Foreground="{DynamicResource SemiColorText2}"/>
              <TextBlock Canvas.Left="8" Canvas.Top="34" Text="5 Gbps" FontSize="9" Foreground="{DynamicResource SemiColorText2}"/>
              <TextBlock Canvas.Left="8" Canvas.Top="74" Text="2.5 Gbps" FontSize="9" Foreground="{DynamicResource SemiColorText2}"/>
              <TextBlock Canvas.Left="8" Canvas.Top="114" Text="1 Gbps" FontSize="9" Foreground="{DynamicResource SemiColorText2}"/>
              <TextBlock Canvas.Left="8" Canvas.Top="134" Text="500 Mbps" FontSize="9" Foreground="{DynamicResource SemiColorText2}"/>
              <TextBlock Canvas.Left="8" Canvas.Top="154" Text="300 Mbps" FontSize="9" Foreground="{DynamicResource SemiColorText2}"/>
              <TextBlock Canvas.Left="8" Canvas.Top="174" Text="100 Mbps" FontSize="9" Foreground="{DynamicResource SemiColorText2}"/>

              <!-- Chart Polylines -->
              <Polyline Points="{Binding DownloadPoints}" Stroke="{DynamicResource CyanAccent}" StrokeThickness="2.5" StrokeJoin="Round"/>
              <Polyline Points="{Binding UploadPoints}" Stroke="{DynamicResource PinkAccent}" StrokeThickness="2" StrokeJoin="Round" Opacity="0.85"/>
            </Canvas>
          </Grid>
        </Border>

        <!-- Bandwidth Monitor (Circular Progress) -->
        <Border Grid.Column="1" Classes="Card" Margin="6">
          <Grid RowDefinitions="Auto, *">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
              <ic:SymbolIcon Symbol="Clock" FontSize="18" Foreground="{DynamicResource CyanAccent}" VerticalAlignment="Center"/>
              <TextBlock Text="Giám Sát Băng Thông" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
            </StackPanel>
            
            <UniformGrid Grid.Row="1" Columns="2" VerticalAlignment="Center">
              <!-- Download Usage Ring -->
              <Grid Margin="4" Width="160" Height="160">
                <Ellipse Stroke="{DynamicResource SemiColorBorder}" StrokeThickness="10" Width="150" Height="150" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Arc Stroke="{DynamicResource CyanAccent}" StrokeThickness="10" 
                     StartAngle="-90" SweepAngle="{Binding DownloadUseAngle}" 
                     Width="150" Height="150" 
                     StrokeLineCap="Round" StrokeJoin="Round"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                  <ic:SymbolIcon Symbol="ArrowDownload" FontSize="24" HorizontalAlignment="Center" Foreground="{DynamicResource CyanAccent}"/>
                  <TextBlock Text="{Binding DownloadSpeedText}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SemiColorText0}" HorizontalAlignment="Center" Margin="0,4"/>
                  <TextBlock Text="Download Use" FontSize="9" Foreground="{DynamicResource TextGray}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding DownloadUsePercentage, StringFormat={}{0:F0}%}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource CyanAccent}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
              </Grid>

              <!-- Upload Usage Ring -->
              <Grid Margin="4" Width="160" Height="160">
                <Ellipse Stroke="{DynamicResource SemiColorBorder}" StrokeThickness="10" Width="150" Height="150" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Arc Stroke="{DynamicResource PinkAccent}" StrokeThickness="10" 
                     StartAngle="-90" SweepAngle="{Binding UploadUseAngle}" 
                     Width="150" Height="150" 
                     StrokeLineCap="Round" StrokeJoin="Round"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                  <ic:SymbolIcon Symbol="ArrowUpload" FontSize="24" HorizontalAlignment="Center" Foreground="{DynamicResource PinkAccent}"/>
                  <TextBlock Text="{Binding UploadSpeedText}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SemiColorText0}" HorizontalAlignment="Center" Margin="0,4"/>
                  <TextBlock Text="Upload Use" FontSize="9" Foreground="{DynamicResource TextGray}" HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding UploadUsePercentage, StringFormat={}{0:F0}%}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PinkAccent}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
              </Grid>
            </UniformGrid>
          </Grid>
        </Border>
      </Grid>


      
    </Grid>
  </ScrollViewer>
</UserControl>
